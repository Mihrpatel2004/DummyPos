@{
    ViewData["Title"] = "Role Management Add Role";
    Layout = "_AdminLayout";
}
@model DummyPos.Models.Role

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Role</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Role_Desc" class="form-control" placeholder="Enter role name" required />
                            <label asp-for="Role_Desc">Role Description</label>
                            <span asp-validation-for="Role_Desc" class="text-danger"></span>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="Is_Active" id="activeCheck" checked>
                            <label class="form-check-label fw-bold" for="activeCheck">Set as Active Role</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success shadow-sm">
                                <i class="bi bi-check-lg me-1"></i> Save Role
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}