@model DummyPos.Models.Staffs
@{
    ViewData["Title"] = "Admin Profile";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Safely get the first letter
    string firstLetter = "A";
    if (!string.IsNullOrEmpty(Model?.Staff_Name))
    {
        firstLetter = Model.Staff_Name.Substring(0, 1).ToUpper();
    }
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    /* --- VIBRANT FUTURE-LIGHT BACKGROUND --- */
    .profile-wrapper {
        background: radial-gradient(circle at top right, #e0e7ff, #f8fafc 50%),
                    radial-gradient(circle at bottom left, #f1f5f9, #ffffff 100%);
        background-attachment: fixed;
        min-height: 100vh;
        padding: 50px 20px;
        margin: -20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* --- HOLOGRAPHIC AVATAR SECTION --- */
    .profile-hero {
        text-align: center;
        margin-bottom: 40px;
    }

    .avatar-hologram {
        width: 140px;
        height: 140px;
        background: linear-gradient(135deg, #3b82f6, #00d2ff);
        color: white;
        font-size: 65px;
        font-weight: 800;
        border-radius: 40px; /* Modern "Squircle" shape */
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
        box-shadow: 0 20px 40px rgba(59, 130, 246, 0.3);
        border: 5px solid white;
        position: relative;
    }

    .avatar-hologram::after {
        content: "";
        position: absolute;
        width: 110%;
        height: 110%;
        border: 2px dashed #3b82f6;
        border-radius: 45px;
        animation: rotate-slow 10s linear infinite;
        opacity: 0.3;
    }

    @@keyframes rotate-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .profile-title {
        font-weight: 900;
        font-size: 2.2rem;
        color: #1e293b;
        letter-spacing: -1.5px;
        margin-bottom: 5px;
    }

    .status-badge {
        background: #dcfce7;
        color: #10b981;
        padding: 6px 18px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        display: inline-block;
    }

    /* --- INFO CARDS (GLASSMORPHISM) --- */
    .glass-profile-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 32px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    }

    .section-label {
        font-size: 0.8rem;
        font-weight: 800;
        color: #3b82f6;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 30px;
        display: block;
        border-left: 4px solid #3b82f6;
        padding-left: 12px;
    }

    /* Info Node Styling */
    .info-node {
        margin-bottom: 30px;
        padding: 20px;
        background: #f8fafc;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        transition: all 0.3s;
    }

    .info-node:hover {
        background: white;
        transform: scale(1.02);
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        border-color: #3b82f6;
    }

    .node-label {
        font-size: 0.7rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }

    .node-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        display: block;
    }

    .icon-box {
        width: 40px;
        height: 40px;
        background: white;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
        margin-bottom: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    /* --- ACTION BUTTONS --- */
    .btn-edit-profile {
        background: linear-gradient(135deg, #3b82f6, #00d2ff);
        color: white;
        border: none;
        padding: 15px 30px;
        border-radius: 18px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: 100%;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.2);
    }

    .btn-edit-profile:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4);
        color: white;
    }
</style>

<div class="profile-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-9 col-lg-10">

                @if (Model != null)
                {
                    <div class="profile-hero">
                        <div class="avatar-hologram">
                            @firstLetter
                        </div>
                        <h1 class="profile-title">@Model.Staff_Name</h1>
                        <span class="status-badge">
                            <i class="fas fa-check-circle mr-1"></i> Authorized Administrator
                        </span>
                    </div>

                    <div class="glass-profile-card">
                        <span class="section-label">Admin Profile</span>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-user-shield"></i></div>
                                    <span class="node-label">Full  Name</span>
                                    <span class="node-value">@Model.Staff_Name</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-envelope-open-text"></i></div>
                                    <span class="node-label">Secure Email</span>
                                    <span class="node-value">@(string.IsNullOrEmpty(Model.Email) ? "Not Provided" : Model.Email)</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-id-badge"></i></div>
                                    <span class="node-label">Contact Number</span>
                                    <span class="node-value">@(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node" style="border-left: 4px solid #10b981;">
                                    <div class="icon-box" style="color: #10b981;"><i class="fas fa-network-wired"></i></div>
                                    <span class="node-label">Current Working Branch</span>
                                    <span class="node-value">
                                        @{
                                            string displayBranchName = "Global Admin HQ";
                                            if (Model.BranchId != null && Model.BranchId > 0 && ViewBag.Branches != null)
                                            {
                                                foreach (var branch in ViewBag.Branches)
                                                {
                                                    // Dynamic check for both naming conventions
                                                    var bId = branch.GetType().GetProperty("BranchId")?.GetValue(branch) ?? branch.GetType().GetProperty("Branch_Id")?.GetValue(branch);
                                                    var bName = branch.GetType().GetProperty("BranchName")?.GetValue(branch) ?? branch.GetType().GetProperty("Branch_Name")?.GetValue(branch);

                                                    if (bId != null && (int)bId == Model.BranchId)
                                                    {
                                                        displayBranchName = bName?.ToString() ?? "Unknown Node";
                                                        break;
                                                    }
                                                }
                                            }
                                        }
                                        @displayBranchName
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-calendar-check"></i></div>
                                    <span class="node-label">Joining Date</span>
                                    <span class="node-value">
                                        @(Model.Hire_Date != null && Model.Hire_Date.Value.Year > 2000 ? Model.Hire_Date.Value.ToString("dd MMMM, yyyy") : "Historical Record")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="h-100 d-flex align-items-center">
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="glass-profile-card text-center py-5">
                        <i class="fas fa-user-secret fa-4x text-danger mb-4"></i>
                        <h2 class="fw-bold">Identity Not Verified</h2>
                        <p class="text-muted">The system could not retrieve this profile's data. Authentication failure.</p>
                        <a href="/" class="btn btn-primary rounded-pill px-5 py-2 mt-3">Re-Authenticate</a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>