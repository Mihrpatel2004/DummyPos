

@model IEnumerable<DummyPos.Models.AdminOrderViewModel>
@using System.Linq

@{
    ViewData["Title"] = "All Orders";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* --- VIBRANT FUTURE-LIGHT BACKGROUND --- */
    .admin-report-wrapper {
        background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%);
        background-attachment: fixed;
        min-height: 100vh;
        padding: 40px;
        margin: -20px;
        font-family: 'Poppins', 'Segoe UI', sans-serif;
    }

    .page-main-title {
        background: linear-gradient(90deg, #3a7bd5 0%, #00d2ff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 2.2rem;
        letter-spacing: -1px;
        margin-bottom: 30px;
    }

    /* --- GLASSMORPHISM FILTER PANEL --- */
    .glass-filter-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 35px;
        box-shadow: 0 10px 30px rgba(58, 123, 213, 0.08);
    }

    .filter-tag {
        font-size: 0.75rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
        display: block;
    }

    .modern-input {
        background: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 15px;
        font-weight: 600;
        color: #334155;
        transition: all 0.3s;
    }

        .modern-input:focus {
            border-color: #3a7bd5;
            box-shadow: 0 0 0 4px rgba(58, 123, 213, 0.1);
            outline: none;
        }

    .btn-sync {
        background: linear-gradient(45deg, #3a7bd5, #00d2ff);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 5px 15px rgba(58, 123, 213, 0.3);
        transition: all 0.3s;
    }

        .btn-sync:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(58, 123, 213, 0.5);
            color: white;
        }

    /* --- PREMIUM DATA TABLE --- */
    .report-card {
        background: #ffffff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.04);
        border: 1px solid #f1f5f9;
    }

    .report-header {
        padding: 20px 30px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .result-badge {
        background: #dcfce7;
        color: #166534;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.85rem;
    }

    .table-future {
        width: 100%;
        margin-bottom: 0;
    }

        .table-future thead {
            background-color: #f1f5f9;
        }

        .table-future th {
            color: #475569;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 20px;
            border: none;
        }

        .table-future td {
            padding: 20px;
            vertical-align: middle;
            border-bottom: 1px solid #f8fafc;
            color: #334155;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .table-future tbody tr:hover {
            background-color: #f1f7ff;
        }

    /* --- HIGHLIGHTS --- */
    .order-pill {
        color: #3a7bd5;
        background: #eff6ff;
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 800;
    }

    .branch-tag {
        background: #f1f5f9;
        color: #64748b;
        padding: 5px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .price-text {
        color: #059669;
        font-weight: 800;
        font-size: 1.1rem;
    }

    .status-pill-done {
        background: #10b981;
        color: white;
        padding: 6px 15px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .status-pill-wait {
        background: #f59e0b;
        color: white;
        padding: 6px 15px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
    }
</style>

<div class="admin-report-wrapper">
    <h2 class="page-main-title"><i class="fas fa-file-invoice-dollar mr-2"></i> All Branch Sales Report</h2>

    <div class="glass-filter-card">
        <form method="get" action="@Url.Action("AllOrders", "Admin")">
            <div class="row align-items-end">
                <div class="col-lg-3 col-md-6 mb-3 mb-lg-0">
                    <label class="filter-tag"><i class="fas fa-store-alt mr-1"></i> Branch Office</label>
                    <select name="branchId" class="form-control modern-input">
                        <option value="0">-- ALL LOCATIONS --</option>
                        @foreach (var b in ViewBag.Branches)
                        {
                            if (ViewBag.SelectedBranch != null && (int)ViewBag.SelectedBranch == b.Branch_Id)
                            {
                                <option value="@b.Branch_Id" selected="selected">@b.Branch_Name</option>
                            }
                            else
                            {
                                <option value="@b.Branch_Id">@b.Branch_Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-3 col-md-6 mb-3 mb-lg-0">
                    <label class="filter-tag"><i class="far fa-calendar-alt mr-1"></i> Start Date</label>
                    <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control modern-input" />
                </div>
                <div class="col-lg-3 col-md-6 mb-3 mb-md-0">
                    <label class="filter-tag"><i class="far fa-calendar-check mr-1"></i> End Date</label>
                    <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control modern-input" />
                </div>
                <div class="col-lg-3 col-md-6">
                    <button type="submit" class="btn-sync w-100">
                        <i class="fas fa-sync-alt mr-2"></i> Update Report
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="report-card">
        <div class="report-header">
            <h5 class="m-0 font-weight-bold" style="color: #1e293b;">Transaction Log</h5>
            <span class="result-badge">
                <i class="fas fa-database mr-1"></i> @Model.Count() Records Found
            </span>
        </div>

        <div class="table-responsive">
            <table class="table table-future text-center">
                <thead>
                    <tr>
                        <th>Order No</th>
                        <th>Timestamp</th>
                        <th>Location</th>
                        <th>Customer</th>
                        <th>Handled By</th>
                        <th>Revenue</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-muted" style="padding: 80px 20px;">
                                <i class="fas fa-folder-open fa-3x mb-3" style="color: #cbd5e1;"></i><br />
                                <h5 class="font-weight-bold">Zero Records Found</h5>
                                <p>Adjust your filters to sync historical data.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><span class="order-pill">@order.Order_No</span></td>
                            <td style="color: #64748b;">@order.Order_Date.ToString("dd MMM, hh:mm tt")</td>
                            <td><span class="branch-tag">@order.Branch_Name</span></td>
                            <td>@order.Customer_Name</td>
                            <td>@order.Staff_Name</td>
                            <td><span class="price-text">₹@order.GrandTotal.ToString("0.00")</span></td>
                            <td>
                                @if (order.Status_Name == "Completed")
                                {
                                    <span class="status-pill-done">Completed</span>
                                }
                                else
                                {
                                    <span class="status-pill-wait">@order.Status_Name</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>