@{
}
@model DummyPos.Models.StaffDetailViewModel
@{
    ViewData["Title"] = "Staff Profile";
    Layout = "_AdminLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-dark text-white p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold"><i class="fas fa-id-badge me-2"></i> Employee Profile</h4>
                        <a href="javascript:history.back()" class="btn btn-sm btn-outline-light"><i class="fas fa-arrow-left"></i> Back</a>
                    </div>
                </div>
                
                <div class="card-body p-4 bg-light">
                    <div class="text-center mb-4">
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow" style="width: 80px; height: 80px; font-size: 2rem;">
                            <i class="fas fa-user"></i>
                        </div>
                        <h3 class="fw-bold mt-3 mb-1">@Model.Staff_Name</h3>
                        <p class="text-muted mb-0 fs-5">@Model.Role_Desc | @Model.Branch_Name</p>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="p-3 bg-white border rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-bold mb-1">Phone Number</small>
                                <span class="fs-6"><i class="fas fa-phone text-secondary me-2"></i>@Model.Phone</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-white border rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-bold mb-1">Email Address</small>
                                <span class="fs-6"><i class="fas fa-envelope text-secondary me-2"></i>@Model.Email</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-white border rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-bold mb-1">Hire Date</small>
                                <span class="fs-6"><i class="fas fa-calendar-alt text-secondary me-2"></i>@(Model.Hire_Date?.ToString("dd MMM yyyy") ?? "N/A")</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-white border rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-bold mb-1">Salary</small>
                                <span class="fs-6 fw-bold text-success"><i class="fas fa-rupee-sign me-1"></i>@(Model.Salary?.ToString("0.00") ?? "N/A")</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-white border rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-bold mb-1">System Username</small>
                                <span class="fs-6"><i class="fas fa-desktop text-secondary me-2"></i>@Model.Username</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-white border rounded shadow-sm h-100">
                                <small class="text-muted d-block fw-bold mb-1">Last Login</small>
                                <span class="fs-6"><i class="fas fa-clock text-secondary me-2"></i>@(Model.Last_Login?.ToString("dd MMM yyyy, hh:mm tt") ?? "Never")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>