<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pizza Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/AdminLayout.css" asp-append-version="true" />
</head>
<body>

    <div class="d-flex" id="wrapper">
        <div class="bg-dark-sidebar" id="sidebar-wrapper">
            <div class="sidebar-heading text-white py-4 px-3">
                <i class="fas fa-pizza-slice me-2 text-warning"></i> <strong> ADMIN Panel </strong>
            </div>
            @* <div class="admin-profile-img-container">
                <img src="~/images/admin-profile.jpg"
                     alt="Admin"
                     class="rounded-circle border border-2 border-white shadow-sm"
                     asp-append-version="true">
            </div> *@
            <div class="list-group list-group-flush">
                @{
                    // Get the current Controller and Action to accurately highlight the exact button
                    var c = ViewContext.RouteData.Values["Controller"]?.ToString();
                    var a = ViewContext.RouteData.Values["Action"]?.ToString();
                }
    
                <a asp-controller="Admin" asp-action="Dashboard" class="list-group-item @(c == "Admin" && a == "Dashboard" ? "active" : "")">
                    <i class="fas fa-tachometer-alt me-3"></i>Dashboard
                </a>
                <a asp-controller="Admin" asp-action="BranchDirectory" class="list-group-item @(c == "Admin" && a == "BranchDirectory" ? "active" : "")">
                    <i class="fas fa-tachometer-alt me-3"></i>Details Branch
                </a>
                <a asp-controller="Admin" asp-action="AllOrders" class="list-group-item @(c == "Admin" && a == "AllOrders" ? "active" : "")">
                    <i class="fas fa-tachometer-alt me-3"></i>Show orders
                </a>
                <a asp-controller="Item" asp-action="Index" class="list-group-item @(c == "Item" ? "active" : "")">
                    <i class="fas fa-shopping-cart me-3"></i>Modified Item
                </a>
                <a asp-controller="Admin" asp-action="StaffList" class="list-group-item @(c == "Admin" && a == "StaffList" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Staff
                </a>
                <a asp-controller="Role" asp-action="Index" class="list-group-item @(c == "Role" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Role
                </a>
                <a asp-controller="Branch" asp-action="BranchList" class="list-group-item @(c == "Branch" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Branch
                </a>
                <a asp-controller="ItemCategory" asp-action="Index" class="list-group-item @(c == "ItemCategory" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Item_category
                </a>
                <a asp-controller="ServiceType" asp-action="Index" class="list-group-item @(c == "ServiceType" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Service Type
                </a>
                <a asp-controller="PaymentType" asp-action="Index" class="list-group-item @(c == "PaymentType" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Payment Type
                </a>
                <a asp-controller="OrderStatus" asp-action="Index" class="list-group-item @(c == "OrderStatus" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Orders Status
                </a>
                <a asp-controller="OrderSource" asp-action="Index" class="list-group-item @(c == "OrderSource" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Orders Source
                </a>
                <a asp-controller="Topping" asp-action="Index" class="list-group-item @(c == "Topping" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Toppings
                </a>
                <a asp-controller="Offer" asp-action="Index" class="list-group-item @(c == "Offer" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage All Offer
                </a>
   
                <a asp-controller="FeedbackType" asp-action="Index" class="list-group-item @(c == "FeedbackType" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Manage Feedback Type
                </a>
                <a asp-controller="ItemGstRate" asp-action="Index" class="list-group-item @(c == "ItemGstRate" ? "active" : "")">
                    <i class="fas fa-utensils me-3"></i>Item GST-Rate
                </a>

                <li class="nav-item mt-4" style="border-top: 1px solid #444; padding-top: 10px;">
                    <a href="@Url.Action("Profile", "Admin")" class="nav-link text-center" title="Admin Profile">
                        <i class="fas fa-user-cog" style="font-size: 1.5rem; color: #ccc;"></i>
                    </a>
                </li>
                <br />

                <form asp-controller="Auth" asp-action="Logout" method="post">
                    <button type="submit" class="list-group-item bg-transparent border-0 text-start w-100">
                        <i class="fas fa-sign-out-alt me-3"></i> Log Out
                    </button>
                </form>
            </div>
        </div>
      @*   <div class="ms-auto d-flex align-items-center text-white">
        <i class="fas fa-bell me-3" style="cursor:pointer;"></i>

        <div class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center text-white p-0" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="me-2 d-none d-md-inline">Welcome, <strong>Admin</strong></span>

                <div class="admin-profile-img-container">
                    <img src="~/images/admin-profile.jpg"
                         alt="Admin"
                         class="rounded-circle border border-2 border-white shadow-sm"
                         asp-append-version="true">
                </div>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="adminDropdown">
                <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2"></i> Profile</a></li>
                <li><a class="dropdown-item" href="#"><i class="fas fa-cog me-2"></i> Settings</a></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="fas fa-sign-out-alt me-2"></i> Log Out
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
 *@
        <div  id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-red border-bottom shadow-sm">
                <div class="container-fluid">
                    <button class="btn text-white" id="menu-toggle"><i class="fas fa-bars"></i></button>
        
                    <div class="ms-auto d-flex align-items-center" style="gap: 15px;">
            
                        @{
                            // Safely grab the user's name and first letter so it never crashes
                            string userName = User.Identity?.Name ?? "Admin";
                            string initial = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "A";
                        }

                        <span class="text-white d-none d-md-inline" style="font-size: 1rem;">
                            Welcome, <strong>@userName</strong>
                        </span>

                        <a href="@Url.Action("Profile", "Admin")" title="Admin Profile" style="text-decoration: none;">
                            <div style="width: 40px; height: 40px; background-color: #ffffff; color: #C0392B; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem; box-shadow: 0 3px 6px rgba(0,0,0,0.15);">
                                @initial
                            </div>
                        </a>

                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-light text-danger fw-bold shadow-sm" style="height: 40px; display: flex; align-items: center; border-radius: 8px;">
                                <i class="fas fa-sign-out-alt me-2"></i> Logout
                            </button>
                        </form>

                    </div>
                </div>
            </nav>

            <div class="container-fluid px-4 py-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Toggle Sidebar Script
        document.getElementById("menu-toggle").addEventListener("click", function() {
            document.getElementById("wrapper").classList.toggle("toggled");
        });
    </script>
</body>
</html>