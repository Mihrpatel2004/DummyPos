@{
}
@model List<DummyPos.Models.ItemSearchViewModel>
@{
    ViewData["Title"] = "Search Results";
    Layout = "_Layout";
}

<div class="container mt-5 pt-4">
    <div class="row mb-4">
        <div class="col-12 text-center text-md-start">
            <h2 class="fw-bold">Search Results for "<span class="text-danger">@ViewBag.SearchTerm</span>"</h2>
            <p class="text-muted">Found @Model.Count items matching your search.</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-light text-center p-5 rounded-4 border shadow-sm" role="alert">
            <i class="bi bi-search display-1 text-muted mb-3 d-block"></i>
            <h4 class="fw-bold text-dark">Oops! We couldn't find any items.</h4>
            <p class="text-muted mb-0">Try searching for something else like "Pizza", "Burger", or "Coke".</p>
            <a href="@Url.Action("Pizza", "Home")" class="btn btn-outline-danger mt-4 px-4 rounded-pill fw-bold">Back to Menu</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 menu-item-card">
                    
                        <img src="@item.ImageDataUrl" class="card-img-top rounded-top-4" alt="@item.Item_Name" style="height: 200px; object-fit: cover;">
                        <div class="card-body text-center d-flex flex-column">
                            <h5 class="fw-bold item-name">@item.Item_Name</h5>
                            
                            <h4 class="text-danger fw-bold mt-auto mb-3">₹@item.Amount.ToString("0.00")</h4>
                            
                          
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>