@{
    Layout = "_Layout";
    ViewData["Title"] = "Pizza Menu";
}

<link rel="stylesheet" href="~/css/Pizza.css" />

<div class="pizza-menu-container">
    <div class="container py-5">
        <div class="text-center mb-5 text-white">
            <h1 class="display-4 fw-bold">Our Signature Pizzas</h1>
            <p class="lead">Freshly baked, handcrafted, and delivered hot.</p>
        </div>
       
        <div class="row g-4">
            
            @if (ViewBag.AllPizzaItem != null)
            {
                foreach (var item in ViewBag.AllPizzaItem)
                {
                    <div class="col-md-4 col-lg-3">
                        <div class="card pizza-card h-100 border-0 shadow-lg">
                            <div class="position-relative">
                                <img src="@item.ImageDataUrl" class="card-img-top pizza-img" alt="@item.Item_Name" style="height: 200px; object-fit: cover;">
                                
                                <span class="badge bg-danger position-absolute top-0 end-0 m-3 p-2">₹@item.Amount.ToString("0")</span>
                            </div>
                            <div class="card-body text-center d-flex flex-column justify-content-between">
                                <div>
                                    <h5 class="card-title fw-bold">@item.Item_Name</h5>
                                    
                                    <p class="card-text text-muted small">Prep Time: @item.Prepare_Time_Minutes mins</p>
                                </div>
                                
                               @*  <a href="@Url.Action("Details", "Home", new { id = item.Item_Id })" class="btn btn-pizza w-100 rounded-pill mt-3">View Details</a> *@
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-white py-5">
                    <i class="fas fa-pizza-slice fa-3x mb-3 text-danger"></i>
                    <h3>Our ovens are warming up! Menu updating soon.</h3>
                </div>
            }

        </div>
    </div>
</div>