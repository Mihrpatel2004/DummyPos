@{
}
@{
    ViewData["Title"] = "Add Table";
    Layout = "_AdminLayout";
}
@model DummyPos.Models.RestaurantTable

<div class="container mt-4">
    <div class="card col-md-6 offset-md-3 shadow">
        <div class="card-header bg-primary text-white">
            <h4>Add New Table</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <input type="hidden" asp-for="Branch_Id" />

                <div class="mb-3">
                    <label asp-for="Table_Number" class="form-label"></label>
                    <input asp-for="Table_Number" class="form-control" placeholder="e.g. 5, T-10, Patio-2" />
                    <span asp-validation-for="Table_Number" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Table_Desc" class="form-label"></label>
                    <input asp-for="Table_Desc" class="form-control" placeholder="e.g. Near the window" />
                    <span asp-validation-for="Table_Desc" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Size" class="form-label"></label>
                    <input asp-for="Size" class="form-control" type="number" placeholder="4" />
                    <span asp-validation-for="Size" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Available">Available</option>
                        <option value="Occupied">Occupied</option>
                        <option value="Reserved">Reserved</option>
                        <option value="Out of Service">Out of Service</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success px-4">Save Table</button>
                <a asp-action="Index" asp-route-branchId="@Model.Branch_Id" class="btn btn-secondary px-4">Cancel</a>
            </form>
        </div>
    </div>
</div>