@model DummyPos.Models.LoginViewModel
@{
    Layout = null; // No sidebars or navigation bars on the login screen
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Pizza POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            body {
                background-color: #f8f9fa; /* Light gray background */
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                width: 100%;
                max-width: 400px;
                border-radius: 10px;
            }

            .brand-icon {
                font-size: 3rem;
                color: #dc3545; /* Bootstrap danger red for Pizza theme */
            }
    </style>
</head>
<body>

    <div class="card shadow login-card border-0">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <i class="fas fa-pizza-slice brand-icon mb-3"></i>
                <h3 class="fw-bold text-dark">PIZZA POS</h3>
                <p class="text-muted">Please sign in to your account</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success fw-bold text-center small mb-3">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger fw-bold text-center mb-3"></div>

            <form asp-controller="Auth" asp-action="Login" method="post">

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="admin@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-bold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-lock text-muted"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="Enter password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="text-end mb-3">
                    <a href="#" onclick="goToChangePassword(); return false;" class="small text-decoration-none">Change Password?</a>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg fw-bold">
                        <i class="fas fa-sign-in-alt me-2"></i> Login
                    </button>
                </div>
            </form>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function goToChangePassword() {
        // 1. Find the email text box using the ID generated by asp-for="Email"
        let emailInput = document.getElementById('Email');
            
        // 2. Get the text they typed (and remove any accidental spaces)
        let emailValue = emailInput ? emailInput.value.trim() : '';

        // 3. Check if they actually typed something
        if (emailValue !== '') {
        // If yes, send them to the Change Password screen and carry the email in the URL!
        window.location.href = '/Auth/ChangePassword?email=' + encodeURIComponent(emailValue);
        } else {
        // If no, politely ask them to type it and put the blinking cursor in the box for them
        alert("Please type your Email Address in the box first, then click 'Change Password?'.");
        if (emailInput) {
        emailInput.focus();
        }
        }
        }
    </script>
</body>
</html>
