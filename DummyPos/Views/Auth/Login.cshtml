@model DummyPos.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - POS Enterprise</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #ffffff;
                margin: 0;
                overflow-x: hidden;
            }

            /* The left side form container */
            .login-panel {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 4rem;
                background-color: #ffffff;
            }

            .brand-logo {
                width: 48px;
                height: 48px;
                background-color: #E5383B; /* Premium Restaurant Red */
                color: white;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 12px;
                font-size: 1.5rem;
                margin-bottom: 1.5rem;
            }

            /* Clean, minimalist input fields */
            .minimal-input {
                background-color: #f9fafb;
                border: 1px solid #e5e7eb;
                border-radius: 8px;
                padding: 12px 16px;
                font-size: 0.95rem;
                width: 100%;
                color: #111827;
                transition: all 0.2s;
            }

                .minimal-input:focus {
                    background-color: #ffffff;
                    border-color: #E5383B;
                    box-shadow: 0 0 0 4px rgba(229, 56, 59, 0.1);
                    outline: none;
                }

            .minimal-label {
                font-size: 0.85rem;
                font-weight: 500;
                color: #374151;
                margin-bottom: 0.4rem;
            }

            /* Solid, authoritative button */
            .btn-enterprise {
                background-color: #E5383B;
                color: white;
                border: none;
                border-radius: 8px;
                padding: 14px;
                font-weight: 600;
                font-size: 1rem;
                transition: background-color 0.2s;
            }

                .btn-enterprise:hover {
                    background-color: #BA1826;
                    color: white;
                }

            /* The right side full-bleed image */
            .image-panel {
                min-height: 100vh;
                /* Cinematic, dark, high-end restaurant kitchen image */
                background-image: linear-gradient(to right, rgba(0,0,0,0.6), rgba(0,0,0,0.2)), url('https://images.unsplash.com/photo-1590947132387-155cc02f3212?q=80&w=2070&auto=format&fit=crop');
                background-size: cover;
                background-position: center;
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
                padding: 4rem;
            }

            .image-quote {
                color: white;
                max-width: 500px;
            }

            @@media (max-width: 991px) {
                .login-panel {
                    padding: 2rem;
                }
            }
    </style>
</head>
<body>

    <div class="row g-0">
        
        <div class="col-12 col-lg-5 login-panel">
            <div style="max-width: 420px; width: 100%; margin: 0 auto;">
                
                <div class="brand-logo shadow-sm">
                    <i class="fas fa-utensils"></i>
                </div>
                
                <h2 class="fw-bold text-dark mb-2" style="letter-spacing: -0.5px;">Sign in to your System</h2>
                <p class="text-muted mb-4 pb-2" style="font-size: 0.95rem;">Enter your credentials to access the Panel.</p>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success fw-medium small mb-4 rounded-2">
                        <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger fw-medium small mb-3"></div>

                <form asp-controller="Auth" asp-action="Login" method="post">

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label minimal-label">Email Address</label>
                        <input asp-for="Email" class="minimal-input" placeholder="admin@restaurant.com" />
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-5 position-relative">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="Password" class="form-label minimal-label mb-0">Password</label>
                            <a href="#" onclick="goToChangePassword(); return false;" class="text-decoration-none small fw-medium" style="color: #E5383B;">Change password?</a>
                        </div>
                        <input asp-for="Password" class="minimal-input" placeholder="••••••••" type="password" />
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid mt-2">
                        <button type="submit" class="btn btn-enterprise shadow-sm">
                            LogIn
                        </button>
                    </div>
                    
                </form>
            </div>
        </div>

        <div class="col-12 col-lg-7 d-none d-lg-flex image-panel">
            <div class="image-quote">
                <h3 class="fw-bold mb-3" style="font-size: 2.5rem; letter-spacing: -1px;">Streamline your service.</h3>
                <p class="fs-5 text-white-50 mb-0">The all-in-one management platform built for modern, high-volume restaurants.</p>
            </div>
        </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function goToChangePassword() {
        let emailInput = document.getElementById('Email');
        let emailValue = emailInput ? emailInput.value.trim() : '';

        if (emailValue !== '') {
        window.location.href = '/Auth/ChangePassword?email=' + encodeURIComponent(emailValue);
        } else {
        alert("Please type your Email Address in the box first, then click 'Forgot password?'.");
        if (emailInput) {
        emailInput.focus();
        }
        }
        }
    </script>
</body>
</html>