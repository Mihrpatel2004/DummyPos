@{
}
@model DummyPos.Models.ChangePasswordViewModel
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password - Pizza POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f8f9fa; height: 100vh; display: flex; align-items: center; justify-content: center; }
        .auth-card { width: 100%; max-width: 450px; border-radius: 10px; }
    </style>
</head>
<body>
    <div class="card shadow auth-card border-0">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="fas fa-key fa-3x text-warning mb-3"></i>
                <h4 class="fw-bold">Change Password</h4>
                <p class="text-muted small">Enter your current password to create a new one.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 text-center fw-bold small">
                    <i class="fas fa-exclamation-triangle"></i> @ViewBag.Error
                </div>
            }

            <form asp-controller="Auth" asp-action="ChangePassword" method="post">
                
                <div class="mb-3">
                    <label class="form-label fw-bold small">Email Address</label>
                    <input asp-for="Email" class="form-control bg-light" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">Old Password</label>
                    <input asp-for="OldPassword" type="password" class="form-control" placeholder="Enter current password" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" required minlength="4" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-type new password" required minlength="4" />
                </div>

                <button type="submit" class="btn btn-warning w-100 fw-bold mb-3">
                    <i class="fas fa-save me-1"></i> Update Password
                </button>
                
                <div class="text-center">
                    <a href="@Url.Action("Login", "Auth")" class="text-decoration-none small text-secondary">
                        <i class="fas fa-arrow-left"></i> Cancel and go back
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>