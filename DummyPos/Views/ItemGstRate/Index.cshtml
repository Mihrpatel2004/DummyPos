@{
}
@model IEnumerable<DummyPos.Models.ItemGstRate>
@{
    ViewData["Title"] = "Manage Item GST Rates";
    Layout = "_AdminLayout";
}

<div class="card shadow p-3 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Manage GST Rates</h3>
        <a asp-action="Create" class="btn btn-primary">Add New GST Rate</a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Item Name</th>
                <th>Service Type</th>
                <th>GST Rate (%)</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Item_Name</strong></td>
                    <td><span class="badge bg-secondary">@item.Service_Type_Desc</span></td>
                    <td class="text-success fw-bold">@item.GST_Rate.ToString("0.00")%</td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.IGR_Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.IGR_Id" class="btn btn-outline-info btn-sm">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.IGR_Id"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Are you sure you want to completely DELETE this GST rate?')">
                                Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>