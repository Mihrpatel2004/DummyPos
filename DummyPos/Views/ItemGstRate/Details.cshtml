@{
}
@model DummyPos.Models.ItemGstRate
@{
    ViewData["Title"] = "Item GST Rate Details";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="card col-md-6 offset-md-3 shadow border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">GST Rate Details</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-5 text-muted">ID:</dt>
                <dd class="col-sm-7">@Model.IGR_Id</dd>

                <dt class="col-sm-5 text-muted">Item Name:</dt>
                <dd class="col-sm-7 text-primary fw-bold fs-5">@Model.Item_Name</dd>

                <dt class="col-sm-5 text-muted">Service Type:</dt>
                <dd class="col-sm-7">
                    <span class="badge bg-secondary fs-6">@Model.Service_Type_Desc</span>
                </dd>

                <dt class="col-sm-5 text-muted">GST Rate:</dt>
                <dd class="col-sm-7 text-success fw-bold fs-5">@Model.GST_Rate.ToString("0.00")%</dd>
            </dl>
        </div>
        <div class="card-footer bg-light d-flex justify-content-end gap-2">
            <a asp-action="Edit" asp-route-id="@Model.IGR_Id" class="btn btn-warning px-4">Edit</a>
            <a asp-action="Index" class="btn btn-secondary px-4">Back to List</a>
        </div>
    </div>
</div>