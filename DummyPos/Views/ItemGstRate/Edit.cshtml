@{
}
@model DummyPos.Models.ItemGstRate
@{
    ViewData["Title"] = "Edit Item GST Rate";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="card col-md-6 offset-md-3 shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Edit GST Rate</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="IGR_Id" />

                <div class="mb-3">
                    <label asp-for="Item_Id" class="form-label fw-bold"></label>
                    <select asp-for="Item_Id" asp-items="@ViewBag.ItemList" class="form-select"></select>
                    <span asp-validation-for="Item_Id" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Service_Type_Id" class="form-label fw-bold"></label>
                    <select asp-for="Service_Type_Id" asp-items="@ViewBag.ServiceTypeList" class="form-select"></select>
                    <span asp-validation-for="Service_Type_Id" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="GST_Rate" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <input asp-for="GST_Rate" type="number" step="0.01" class="form-control" />
                        <span class="input-group-text">%</span>
                    </div>
                    <span asp-validation-for="GST_Rate" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}