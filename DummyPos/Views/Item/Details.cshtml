@model DummyPos.Models.Item
@{
    ViewData["Title"] = "Item Details";
    Layout = "_AdminLayout";
}

<style>
    /* Admin Dashboard Box Styling */
    .admin-detail-card {
        border-radius: 8px;
        transition: box-shadow 0.2s ease-in-out;
    }
    .admin-detail-card:hover {
        box-shadow: 0 8px 15px rgba(0,0,0,0.05) !important;
    }
    .property-label {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .property-value {
        color: #2b2f32;
        font-weight: 700;
        font-size: 1.1rem;
    }
</style>

<div class="container-fluid py-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="h3 mb-0 text-dark fw-bold"><i class="fas fa-file-alt text-primary me-2"></i> Item Details</h2>
            <p class="text-muted mb-0">Complete database record for this menu item</p>
        </div>
        <a href="/Item/Index" class="btn btn-outline-secondary shadow-sm px-4">
            <i class="fas fa-arrow-left me-2"></i> Back to Item List
        </a>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-danger shadow-sm border-0"><i class="fas fa-exclamation-triangle me-2"></i> Error: Item record could not be found in the database.</div>
        return; 
    }

    <div class="row g-4">
        
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow-sm border-0 admin-detail-card h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 font-weight-bold text-primary">Item Media & Status</h6>
                </div>
                <div class="card-body text-center d-flex flex-column">
                    
                    <div class="bg-light rounded p-3 mb-4 d-flex align-items-center justify-content-center" style="height: 260px; border: 1px dashed #ced4da;">
                        @if (!string.IsNullOrEmpty(Model.ImageDataUrl))
                        {
                            <img src="@Model.ImageDataUrl" alt="@Model.Item_Name" class="img-fluid rounded" style="max-height: 240px; object-fit: contain;" />
                        }
                        else
                        {
                            <div class="text-muted opacity-50">
                                <i class="fas fa-image fa-5x mb-2 d-block"></i>
                                <span>No Image Uploaded</span>
                            </div>
                        }
                    </div>

                    <h4 class="fw-bold mb-1">@Model.Item_Name</h4>
                    
                    <div class="mb-4">
                        @if (Model.Is_Active)
                        {
                            <span class="badge bg-success px-4 py-2 fs-6 rounded-pill"><i class="fas fa-check-circle me-1"></i> Active in System</span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-4 py-2 fs-6 rounded-pill"><i class="fas fa-times-circle me-1"></i> Disabled</span>
                        }
                    </div>

                    <div class="mt-auto d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Item_Id" class="btn btn-primary"><i class="fas fa-edit me-2"></i> Edit Record</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            <div class="row g-4">
                
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 admin-detail-card border-top border-primary border-3 h-100">
                        <div class="card-body p-4">
                            <h5 class="text-primary fw-bold mb-4"><i class="fas fa-info-circle me-2"></i> Basic Information</h5>
                            
                            <div class="mb-3">
                                <div class="property-label mb-1">Item ID (Primary Key)</div>
                                <div class="property-value">#@Model.Item_Id</div>
                            </div>
                            
                            <hr class="text-muted opacity-25">
                            
                            <div class="mb-3">
                                <div class="property-label mb-1">Registered Name</div>
                                <div class="property-value">@Model.Item_Name</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card shadow-sm border-0 admin-detail-card border-top border-success border-3 h-100">
                        <div class="card-body p-4">
                            <h5 class="text-success fw-bold mb-4"><i class="fas fa-tags me-2"></i> Pricing & Operations</h5>
                            
                            <div class="mb-3">
                                <div class="property-label mb-1">Selling Amount</div>
                                <div class="property-value text-success fs-3">₹@Model.Amount.ToString("0.00")</div>
                            </div>
                            
                            <hr class="text-muted opacity-25">
                            
                            <div class="mb-3">
                                <div class="property-label mb-1">Kitchen Prep Time</div>
                                <div class="property-value">
                                    @if (Model.Prepare_Time_Minutes.HasValue && Model.Prepare_Time_Minutes > 0)
                                    {
                                        <span><i class="fas fa-clock text-warning me-2"></i> @Model.Prepare_Time_Minutes Minutes</span>
                                    }
                                    else
                                    {
                                        <span><i class="fas fa-bolt text-warning me-2"></i> Instant / Ready-made</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card shadow-sm border-0 admin-detail-card border-top border-info border-3">
                        <div class="card-body p-4">
                            <h5 class="text-info fw-bold mb-4"><i class="fas fa-layer-group me-2"></i> Categorization & Layout</h5>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <div class="property-label mb-1">Category Foreign Key ID</div>
                                    <div class="property-value">@Model.Item_Category_Id</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="property-label mb-1">Category Description</div>
                                    <div class="property-value">
                                        <span class="badge bg-light text-dark border px-3 py-2 fs-6">
                                            @Model.Item_Category_Desc
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        
    </div>
</div>