    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{

    ViewData["Title"] = "Item Create";
    Layout = "_AdminLayout";
}
@model DummyPos.Models.Item

<div class="container mt-4">
    <div class="card col-md-8 offset-md-2 shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Add New Item</h4>
        </div>
        <div class="card-body">
            <!-- IMPORTANT: enctype="multipart/form-data" is absolutely required to upload files! -->
            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Item_Name" class="form-label fw-bold"></label>
                        <input asp-for="Item_Name" class="form-control" placeholder="e.g. Deluxe Burger" />
                        <span asp-validation-for="Item_Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Item_Category_Id" class="form-label fw-bold"></label>
                        <select asp-for="Item_Category_Id" asp-items="@ViewBag.CategoryList" class="form-select">
                            <option value="">-- Select a Category --</option>
                        </select>
                        <span asp-validation-for="Item_Category_Id" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Amount" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Prepare_Time_Minutes" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="Prepare_Time_Minutes" type="number" class="form-control" placeholder="e.g. 15" />
                            <span class="input-group-text">Minutes</span>
                        </div>
                        <span asp-validation-for="Prepare_Time_Minutes" class="text-danger"></span>
                    </div>
                </div>

                <!-- FILE UPLOAD FIELD -->
                <div class="mb-4 bg-light p-3 rounded border">
                    <label asp-for="ImageUpload" class="form-label fw-bold text-primary"></label>
                    <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" />
                    <small class="text-muted d-block mt-1">Select an image from your computer to display on the menu (JPEG, PNG, etc.).</small>
                    <span asp-validation-for="ImageUpload" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="Is_Active" class="form-check-input" type="checkbox" />
                    <label asp-for="Is_Active" class="form-check-label fw-bold">Item is available for sale</label>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-success px-4">Save Item</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}