    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Item Index";
    Layout = "_AdminLayout";
}
@model IEnumerable<DummyPos.Models.Item>

<div class="card shadow p-3 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Manage Items</h3>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Item
        </a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th class="text-center">Image</th>
                <th>Item Name</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Prep Time</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@item.ImageDataUrl" alt="@item.Item_Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;" />
                        </td>
                        <td><strong>@item.Item_Name</strong></td>
                        <td>@item.Item_Category_Desc</td>
                        <td>@item.Amount.ToString("C")</td>
                        <td>@(item.Prepare_Time_Minutes.HasValue ? $"{item.Prepare_Time_Minutes} mins" : "-")</td>
                        <td>
                            @if (item.Is_Active)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Item_Id" class="btn btn-outline-primary btn-sm">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Item_Id" class="btn btn-outline-info btn-sm">Details</a>

                                @if (item.Is_Active)
                                {
                                    <a asp-action="DeactivateItem" asp-route-id="@item.Item_Id"
                                       class="btn btn-outline-warning btn-sm"
                                       onclick="return confirm('Deactivate this item?')">
                                        <i class="bi bi-slash-circle"></i> Deactivate
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="ActivateItem" asp-route-id="@item.Item_Id"
                                       class="btn btn-outline-success btn-sm"
                                       onclick="return confirm('Activate this item?')">
                                        <i class="bi bi-check-circle"></i> Activate
                                    </a>
                                }

                                <a asp-action="Delete" asp-route-id="@item.Item_Id"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to completely DELETE this item? This action cannot be undone.')">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">No items found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>