    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Item Edit";
    Layout = "_AdminLayout";
}
@model DummyPos.Models.Item

<div class="container mt-4">
    <div class="card col-md-8 offset-md-2 shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Edit Item</h4>
        </div>
        <div class="card-body">
            <!-- IMPORTANT: enctype="multipart/form-data" is absolutely required to upload files! -->
            <form asp-action="Edit" method="post" enctype="multipart/form-data">

                <!-- Hidden field to keep track of the ID being edited -->
                <input type="hidden" asp-for="Item_Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Item_Name" class="form-label fw-bold"></label>
                        <input asp-for="Item_Name" class="form-control" />
                        <span asp-validation-for="Item_Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Item_Category_Id" class="form-label fw-bold"></label>
                        <select asp-for="Item_Category_Id" asp-items="@ViewBag.CategoryList" class="form-select">
                            <option value="">-- Select a Category --</option>
                        </select>
                        <span asp-validation-for="Item_Category_Id" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Amount" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Prepare_Time_Minutes" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="Prepare_Time_Minutes" type="number" class="form-control" />
                            <span class="input-group-text">Minutes</span>
                        </div>
                        <span asp-validation-for="Prepare_Time_Minutes" class="text-danger"></span>
                    </div>
                </div>

                <!-- IMAGE UPLOAD AND PREVIEW -->
                <div class="row mb-4 align-items-center bg-light p-3 rounded border mx-0">
                    <div class="col-md-3 text-center">
                        <p class="mb-1 text-muted small fw-bold">Current Image</p>
                        <!-- Displays the current image from the database using ImageDataUrl -->
                        <img src="@Model.ImageDataUrl" alt="Current Image" class="img-thumbnail shadow-sm" style="max-height: 100px; object-fit: cover;" />
                    </div>
                    <div class="col-md-9">
                        <label asp-for="ImageUpload" class="form-label fw-bold text-primary">Upload New Image</label>
                        <input asp-for="ImageUpload" type="file" class="form-control" accept="image/*" />
                        <small class="text-muted d-block mt-1">Leave this empty if you want to keep the current image.</small>
                        <span asp-validation-for="ImageUpload" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="Is_Active" class="form-check-input" type="checkbox" />
                    <label asp-for="Is_Active" class="form-check-label fw-bold">Item is available for sale</label>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Update Item</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}