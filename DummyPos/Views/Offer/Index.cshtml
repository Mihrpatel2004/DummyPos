@{
}
@{
    ViewData["Title"] = "Offers Index";
    Layout = "_AdminLayout";
}
@model IEnumerable<DummyPos.Models.Offer>

<div class="card shadow p-3 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Smart Offer Campaigns</h3>
        <a asp-action="Create" class="btn btn-primary">Add New Offer</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Campaign Name</th>
                <th>Discount (%)</th>
                <th>Valid Dates</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Offer_Name</strong></td>
                    <td class="text-success fw-bold">@item.Offer_Percent.ToString("0.00")%</td>
                    <td><small>@item.Start_Date.ToString("dd/MMM/yyyy") - @item.End_Date.ToString("dd/MMM/yyyy")</small></td>
                    <td>
                        @if (item.Current_Status == "Running")
                        {
                            <span class="badge bg-success">Running Now</span>
                        }
                        else if (item.Current_Status == "Scheduled")
                        {
                            <span class="badge bg-info">Scheduled</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Paused</span>
                        }
                    </td>
                  
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Offer_Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Offer_Id" class="btn btn-outline-info btn-sm">Details</a>
                            @if (item.Is_Active)
                            {
                                <a asp-action="DeactivateOffer" asp-route-id="@item.Offer_Id" class="btn btn-outline-warning btn-sm" onclick="return confirm('Pause this offer?')">Pause</a>
                            }
                            else
                            {
                                <a asp-action="ActivateOffer" asp-route-id="@item.Offer_Id" class="btn btn-outline-success btn-sm" onclick="return confirm('Activate this offer?')">Activate</a>
                            }

                            <a asp-action="Delete" asp-route-id="@item.Offer_Id" class="btn btn-outline-danger btn-sm" onclick="return confirm('DELETE this offer?')">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>