@{
    ViewData["Title"] = "Edit Screen";
    Layout = "_AdminLayout";
}
@model DummyPos.Models.ItemDisplayScreen
<div class="container mt-4">
    <div class="card col-md-6 offset-md-3 shadow border-0">
        <div class="card-header bg-warning text-dark"><h4>Edit Screen</h4></div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Screen_No" />
                <input type="hidden" asp-for="Station_Id" />

                <div class="mb-3">
                    <label asp-for="Item_Id" class="form-label fw-bold"></label>
                    <select asp-for="Item_Id" asp-items="@ViewBag.ItemList" class="form-select"></select>
                    <span asp-validation-for="Item_Id" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="Is_Active" class="form-check-input" type="checkbox" />
                    <label asp-for="Is_Active" class="form-check-label fw-bold">Is Active?</label>
                </div>
                <button type="submit" class="btn btn-primary px-4">Update</button>
                <a asp-action="Index" asp-route-stationId="@Model.Station_Id" class="btn btn-secondary px-4">Cancel</a>
            </form>
        </div>
    </div>
</div>