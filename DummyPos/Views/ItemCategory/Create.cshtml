@{
    ViewData["Title"] = "ItemCategory Create";
    Layout = "_AdminLayout";
}
@model DummyPos.Models.ItemCategory

<div class="container mt-4">
    <div class="card col-md-6 offset-md-3 shadow">
        <div class="card-header bg-primary text-white">
            <h4>Add New Item Category</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="Item_Category_Desc" class="form-label"></label>
                    <input asp-for="Item_Category_Desc" class="form-control" placeholder="e.g. Beverages, Main Course" />
                    <span asp-validation-for="Item_Category_Desc" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-3">
                    <input asp-for="Is_Active" class="form-check-input" type="checkbox" />
                    <label asp-for="Is_Active" class="form-check-label">Set as Active</label>
                </div>

                <button type="submit" class="btn btn-success px-4">Save</button>
                <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
            </form>
        </div>
    </div>
</div>