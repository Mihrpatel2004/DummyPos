@{
}
@model IEnumerable<DummyPos.Models.OrderStatus>
@{
    ViewData["Title"] = "Manage Order Statuses";
}

<div class="card shadow p-3 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-danger"><i class="fas fa-list-ul me-2"></i> Manage Order Statuses</h3>
        <a asp-action="Create" class="btn btn-danger">
            <i class="fas fa-plus me-1"></i> Add New Status
        </a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Status Description</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Status_Desc</strong></td>
                    <td>
                        @if (item.Is_Active)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {

                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Status_Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Status_Id" class="btn btn-outline-info btn-sm">Details</a>

                            @if (item.Is_Active)
                            {
                                <a asp-action="DeactivateStatus" asp-route-id="@item.Status_Id"
                                   class="btn btn-outline-warning btn-sm"
                                   onclick="return confirm('Deactivate this status?')">
                                    Deactivate
                                </a>
                            }
                            else
                            {
                                <a asp-action="ActivateStatus" asp-route-id="@item.Status_Id"
                                   class="btn btn-outline-success btn-sm"
                                   onclick="return confirm('Activate this status?')">
                                    Activate
                                </a>
                            }

                            <a asp-action="Delete" asp-route-id="@item.Status_Id"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Are you sure you want to completely DELETE this status?')">
                                Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>