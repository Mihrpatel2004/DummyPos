@model IEnumerable<DummyPos.Models.FeedbackType>
@{
    ViewData["Title"] = "Manage Feedback Types";
    Layout = "_AdminLayout";
}

<div class="card shadow p-3 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Manage Feedback Types</h3>
        <a asp-action="Create" class="btn btn-primary">Add New Type</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Feedback Type Name</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Feedback_Type_Id</td>
                    <td><strong>@item.Feedback_Type_Name</strong></td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@item.Feedback_Type_Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Feedback_Type_Id" class="btn btn-outline-info btn-sm">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Feedback_Type_Id"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Are you sure you want to completely DELETE this feedback type?')">
                                Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>