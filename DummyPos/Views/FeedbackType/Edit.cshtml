    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model DummyPos.Models.FeedbackType
@{
    ViewData["Title"] = "Edit Feedback Type";
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="card col-md-6 offset-md-3 shadow border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Edit Feedback Type</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Feedback_Type_Id" />

                <div class="mb-4">
                    <label asp-for="Feedback_Type_Name" class="form-label fw-bold"></label>
                    <input asp-for="Feedback_Type_Name" class="form-control" />
                    <span asp-validation-for="Feedback_Type_Name" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}