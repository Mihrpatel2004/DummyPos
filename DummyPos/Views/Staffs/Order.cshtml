@*

 @{
    ViewData["Title"] = "POS Terminal";
    Layout = "_StaffsLayout";
}

<style>
    .pos-container { height: calc(100vh - 80px); overflow: hidden; }
    .menu-section { height: 100%; overflow-y: auto; background-color: #f8f9fa; padding: 15px; }
    .cart-section { height: 100%; display: flex; flex-direction: column; background-color: #fff; border-left: 2px solid #eee; }
    .cart-items-wrapper { flex-grow: 1; overflow-y: auto; padding: 15px; }
    .cart-totals { padding: 15px; background: #f8f9fa; border-top: 2px solid #eee; }
    .item-card { transition: box-shadow 0.2s; }
    .item-card:hover { box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
    .add-btn:active { transform: scale(0.95); }
</style>

<div class="container-fluid pos-container">
    <div class="row h-100">
        
        <div class="col-md-7 col-lg-8 menu-section">
            <h3 class="fw-bold mb-3"><i class="fas fa-pizza-slice text-danger"></i> Menu Items</h3>
            
            <div class="mb-3 overflow-auto" style="white-space: nowrap;">
                <button class="btn btn-dark me-2 mb-2" onclick="filterMenu('all')">All Items</button>
                
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <button class="btn btn-outline-dark me-2 mb-2" 
                                onclick="filterMenu(@cat.Item_Category_Id)">
                            @cat.Item_Category_Desc
                        </button>
                    }
                }
            </div>

            <div class="row g-3" id="menuItemsContainer">
                @if (ViewBag.MenuItems != null)
                {
                    foreach (var item in ViewBag.MenuItems)
                    {
                        <div class="col-6 col-md-4 col-lg-3 menu-item-card" data-category-id="@item.Item_Category_Id">
                            <div class="card item-card h-100 border-0 shadow-sm">
                                <img src="@item.ImageDataUrl" class="card-img-top" alt="@item.Item_Name" 
                                     style="height: 120px; object-fit: cover; border-top-left-radius: 8px; border-top-right-radius: 8px;">
                                <div class="card-body text-center p-2 d-flex flex-column justify-content-between">
                                    <div>
                                        <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">@item.Item_Name</h6>
                                        <span class="text-success fw-bold d-block mb-2">₹@item.Amount.ToString("0.00")</span>
                                    </div>
                                    <button class="btn btn-sm btn-primary w-100 fw-bold add-btn" 
                                            data-id="@item.Item_Id"
                                            data-name="@item.Item_Name"
                                            data-price="@item.Amount"
                                            onclick="addToCart(this)">
                                        <i class="fas fa-plus"></i> Add
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center text-muted mt-5">
                        <p>No menu items found. Please add items from the Admin Panel.</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-5 col-lg-4 cart-section p-0">
            <div class="bg-dark text-white p-3 text-center">
                <h5 class="mb-0 fw-bold">Current Order</h5>
            </div>
            
            <div class="cart-items-wrapper">
    
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-2 bg-light rounded">
                        <h6 class="fw-bold mb-2 text-primary" style="font-size: 0.85rem;">
                            <i class="fas fa-user-plus me-1"></i> Customer Details
                        </h6>
                        <div class="input-group input-group-sm mb-2">
                            <span class="input-group-text bg-white"><i class="fas fa-phone"></i></span>
                            <input type="text" id="custPhone" class="form-control fw-bold" placeholder="Phone Number" onblur="lookupCustomer()" maxlength="10">
                        </div>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-white"><i class="fas fa-user"></i></span>
                            <input type="text" id="custName" class="form-control" placeholder="Customer Name">
                        </div>
                        <small id="customerStatus" style="font-size: 0.75rem; display:none;"></small>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body p-2 bg-light rounded">
                        <h6 class="fw-bold mb-2 text-primary" style="font-size: 0.85rem;">
                            <i class="fas fa-utensils me-1"></i> Order Type
                        </h6>
                        <select id="serviceTypeId" class="form-select form-select-sm mb-2" onchange="toggleOrderType()">
                            <option value="1">Dine-In (Eating Here)</option>
                            <option value="2">Takeaway (Parcel)</option>
                        </select>
                        
                        <div id="tableNumberBox" class="input-group input-group-sm mb-2" style="display:none;">
                            <span class="input-group-text bg-white"><i class="fas fa-chair"></i></span>
                            <select id="tableId" class="form-select form-select-sm">
                                <option value="">-- Select Table --</option>
                                @if (ViewBag.Tables != null)
                                {
                                    foreach (var tbl in ViewBag.Tables)
                                    {
                                        string statusText = tbl.Status == "Available" ? "" : $"({tbl.Status})";
                                        <option value="@tbl.Table_Id">@tbl.Table_Number - Seats @tbl.Size @statusText</option>
                                    }
                                }
                            </select>
                        </div>

                    </div>
                </div>

                <div class="text-center text-muted mt-5" id="emptyCartMsg">
                    <i class="fas fa-shopping-basket fa-3x mb-3"></i>
                    <p>Cart is empty</p>
                </div>
                <div id="cartItemsList"></div>

            </div>

            <div class="cart-totals">
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <select id="sourceId" class="form-select form-select-sm">
                            @if (ViewBag.OrderSources != null)
                            {
                                foreach (var src in ViewBag.OrderSources)
                                {
                                    <option value="@src.Source_Id">@src.Source_Desc</option>
                                }
                            }
                            else 
                            {
                                <option value="1">Dine-in</option> }
                        </select>
                    </div>
                 
                    <div class="col-6">
                        <select id="paymentTypeId" class="form-select form-select-sm">
                            @if (ViewBag.PaymentTypes != null)
                            {
                                foreach (var pt in ViewBag.PaymentTypes)
                                {
                                    <option value="@pt.PT_Id">@pt.PT_Desc</option>
                                }
                            }
                            else 
                            {
                                <option value="1">Cash</option> }
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between mb-1">
                    <span>Subtotal:</span>
                    <span class="fw-bold">₹<span id="subTotal">0.00</span></span>
                </div>
                
                <div class="d-flex justify-content-between mb-1 text-success" id="discountRow" style="display:none;">
                    <span>Discount (<span id="discountPercentLabel">0</span>%):</span>
                    <span class="fw-bold">- ₹<span id="discountAmount">0.00</span></span>
                </div>

                <div class="d-flex justify-content-between mb-1 text-danger">
                    <span>GST (18%):</span>
                    <span class="fw-bold">₹<span id="taxAmount">0.00</span></span>
                </div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between mb-3 fs-4 text-success fw-bold">
                    <span>TOTAL:</span>
                    <span>₹<span id="grandTotal">0.00</span></span>
                </div>

                <div id="checkoutButtonsContainer"></div>
            </div>
        </div>
        
    </div>
</div>

@section Scripts {
    <script>
        function filterMenu(categoryId) {
            let items = document.querySelectorAll('.menu-item-card');
            items.forEach(item => {
                if (categoryId === 'all' || item.getAttribute('data-category-id') == categoryId) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        let activeDiscountPercent = @(ViewBag.ActiveDiscount ?? 0);
        let existingOrderId = @(ViewBag.ExistingOrderId ?? 0);
        let cart = []; 

        @if (ViewBag.ExistingOrderData != null)
        {
            var existingData = (DummyPos.Models.CheckoutViewModel)ViewBag.ExistingOrderData;
            foreach (var item in existingData.Items)
            {
                var safeName = item.Item_Name != null ? item.Item_Name.Replace("\"", "\\\"").Replace("'", "\\'") : "Item";
                <text>
                cart.push({
                    Item_Id: @item.Item_Id,
                    Item_Name: "@Html.Raw(safeName)",
                    Unit_Price: @item.Unit_Price,
                    Quantity: @item.Quantity,
                    Total_Price: @item.Total_Price
                });
                </text>
            }
            
            <text>
            window.addEventListener('load', function() {
                document.getElementById("custName").value = "@Html.Raw(existingData.Customer_Name != null ? existingData.Customer_Name.Replace("\"", "\\\"") : "")";
                document.getElementById("custPhone").value = "@Html.Raw(existingData.Customer_Phone ?? "")";
                document.getElementById("serviceTypeId").value = "@existingData.Service_Type_Id";
                
                // 🚨 PREFILL EXISTING TABLE DROPDOWN LOGIC 🚨
                let existingTableId = "@(existingData.Table_Id?.ToString() ?? "")";
                if(existingTableId) {
                    document.getElementById("tableId").value = existingTableId;
                }
                
                toggleOrderType(); 
                refreshCartUI();
            });
            </text>
        }
        else
        {
            <text>
            window.addEventListener('load', function() {
                toggleOrderType(); 
            });
            </text>
        }

        function addToCart(btnElement) {
            let cleanId = parseInt(btnElement.getAttribute('data-id'));
            let itemName = btnElement.getAttribute('data-name');
            let cleanPrice = parseFloat(btnElement.getAttribute('data-price')) || 0;

            let existingItem = cart.find(x => x.Item_Id === cleanId);
            
            if (existingItem) {
                existingItem.Quantity += 1; 
                existingItem.Total_Price = existingItem.Quantity * existingItem.Unit_Price;
            } else {
                cart.push({
                    Item_Id: cleanId,
                    Item_Name: itemName, 
                    Unit_Price: cleanPrice,
                    Quantity: 1,
                    Total_Price: cleanPrice
                });
            }
            refreshCartUI();
        }

        function changeQty(itemId, amount) {
            let cleanId = parseInt(itemId);
            let itemIndex = cart.findIndex(x => x.Item_Id === cleanId);
            
            if (itemIndex !== -1) {
                cart[itemIndex].Quantity += parseInt(amount);
                if (cart[itemIndex].Quantity <= 0) {
                    cart.splice(itemIndex, 1); 
                } else {
                    cart[itemIndex].Total_Price = cart[itemIndex].Quantity * cart[itemIndex].Unit_Price;
                }
                refreshCartUI();
            }
        }

        function refreshCartUI() {
            let listContainer = document.getElementById("cartItemsList");
            let emptyMsg = document.getElementById("emptyCartMsg");
            
            if (cart.length === 0) {
                listContainer.innerHTML = '';
                emptyMsg.style.display = 'block';
                updateTotals(0, 0, 0, 0);
                return;
            }
            
            emptyMsg.style.display = 'none';
            let html = '';
            let subTotal = 0;

            cart.forEach(item => {
                subTotal += item.Total_Price; 

                html += `
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                        <div>
                            <h6 class="mb-0 fw-bold">${item.Item_Name}</h6>
                            <small class="text-muted">₹${item.Unit_Price.toFixed(2)} x ${item.Quantity}</small>
                        </div>
                        <div class="d-flex align-items-center">
                            <button class="btn btn-sm btn-outline-danger px-2 py-0 me-2" onclick="changeQty(${item.Item_Id}, -1)">-</button>
                            <span class="fw-bold me-2">₹${item.Total_Price.toFixed(2)}</span>
                            <button class="btn btn-sm btn-outline-success px-2 py-0" onclick="changeQty(${item.Item_Id}, 1)">+</button>
                        </div>
                    </div>
                `;
            });
            listContainer.innerHTML = html;

            let discountAmount = (subTotal * activeDiscountPercent) / 100;
            let discountedSubtotal = subTotal - discountAmount;
            
            let flatGstPercentage = 18.00; 
            let totalTaxAmount = (discountedSubtotal * flatGstPercentage) / 100;
            let grandTotal = discountedSubtotal + totalTaxAmount;

            updateTotals(subTotal, discountAmount, totalTaxAmount, grandTotal);
        }

        function updateTotals(sub, disc, tax, total) {
            document.getElementById("subTotal").innerText = (sub || 0).toFixed(2);
            document.getElementById("taxAmount").innerText = (tax || 0).toFixed(2);
            document.getElementById("grandTotal").innerText = (total || 0).toFixed(2);

            let discRow = document.getElementById("discountRow");
            if (activeDiscountPercent > 0 && sub > 0) {
                discRow.style.setProperty('display', 'flex', 'important');
                document.getElementById("discountPercentLabel").innerText = activeDiscountPercent;
                document.getElementById("discountAmount").innerText = (disc || 0).toFixed(2);
            } else {
                discRow.style.setProperty('display', 'none', 'important');
            }
        }

        function toggleOrderType() {
            let serviceType = document.getElementById("serviceTypeId").value;
            let tableBox = document.getElementById("tableNumberBox");
            let btnContainer = document.getElementById("checkoutButtonsContainer");

            if (serviceType === "1") { 
                tableBox.style.display = "flex";
                
                if (existingOrderId > 0) {
                    btnContainer.innerHTML = `
                        <div class="d-flex gap-2">
                            <button class="btn btn-warning text-dark w-50 fw-bold py-3" onclick="placeOrder('Open')">
                                <i class="fas fa-sync me-1"></i> Update Order
                            </button>
                            <button class="btn btn-success text-white w-50 fw-bold py-3" onclick="placeOrder('Paid')">
                                <i class="fas fa-check"></i> Settle Bill
                            </button>
                        </div>
                    `;
                } else {
                    btnContainer.innerHTML = `
                        <button class="btn btn-warning text-dark w-100 fw-bold py-3" onclick="placeOrder('Open')">
                            <i class="fas fa-paper-plane me-2"></i> Send to Running Table 
                        </button>
                    `;
                }
            } else { 
                tableBox.style.display = "none";
                document.getElementById("tableId").value = ""; // 🚨 FIX: Reset Table dropdown
                btnContainer.innerHTML = `
                    <button class="btn btn-success text-white w-100 fw-bold py-3" onclick="placeOrder('Paid')">
                        <i class="fas fa-check-circle me-2"></i> Pay & Complete
                    </button>
                `;
            }
        }

        function placeOrder(forceStatus) {
            if (cart.length === 0) {
                alert("Please add items to the cart first!");
                return;
            }

            // 🚨 UPDATED: Ensure we require a table if Dine-In is selected
            let serviceType = document.getElementById("serviceTypeId").value;
            let tblId = document.getElementById("tableId").value;
            
            if (serviceType === "1" && !tblId) {
                alert("Please select a table for Dine-In orders!");
                return;
            }

            let payload = {
                Customer_Name: document.getElementById("custName").value || "Walk-In",
                Customer_Phone: document.getElementById("custPhone").value || "",
                Source_Id: parseInt(document.getElementById("sourceId").value),
                Service_Type_Id: parseInt(serviceType),
                Table_Id: parseInt(tblId) || null, // 🚨 UPDATED TO SEND TABLE ID
                Order_Status: forceStatus || "Open",
                Payment_Type_Id: parseInt(document.getElementById("paymentTypeId").value),
                
                SubTotal: parseFloat(document.getElementById("subTotal").innerText),
                TaxAmount: parseFloat(document.getElementById("taxAmount").innerText),
                GrandTotal: parseFloat(document.getElementById("grandTotal").innerText),
                DiscountAmount: activeDiscountPercent > 0 ? parseFloat(document.getElementById("discountAmount").innerText) : 0, 
                
                Items: cart 
            };

            fetch('/Staffs/SubmitOrder?existingOrderId=' + existingOrderId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(async response => {
                if (!response.ok) {
                    let errorText = await response.text();
                    throw new Error(errorText.substring(0, 300)); 
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    if (forceStatus === "Paid") {
                        // 🚨 THE MAGIC REDIRECT: Go straight to Feedback Page!
                        let finalOrderId = (existingOrderId > 0) ? existingOrderId : data.orderId;
                        window.location.href = '/Staffs/AddOrderFeedback?orderId=' + finalOrderId;
                    } else if (existingOrderId > 0) {
                        window.location.href = '/Staffs/RunningTables';
                    } else {
                        alert("Order Created!");
                        window.location.href = '/Staffs/RunningTables'; 
                    }
                } else {
                    alert("Error saving order: " + data.message);
                }
            })
            .catch(error => {
                console.error("Server Error:", error);
                alert("Server Crash Detail:\n\n" + error.message);
            });
        }

        function lookupCustomer() {
            let phone = document.getElementById("custPhone").value.trim();
            let statusLabel = document.getElementById("customerStatus");
            let nameInput = document.getElementById("custName");

            if (phone.length >= 10) {
                statusLabel.style.display = 'block';
                statusLabel.innerText = "Searching...";
                statusLabel.className = "text-muted d-block mt-1 fw-bold";

                fetch('/Staffs/GetCustomerByPhone?phone=' + phone)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        nameInput.value = data.name;
                        statusLabel.innerText = "✓ Returning Customer Found!";
                        statusLabel.className = "text-success d-block mt-1 fw-bold";
                    } else {
                        nameInput.value = '';
                        statusLabel.innerText = "+ New Customer. Enter name to save.";
                        statusLabel.className = "text-primary d-block mt-1 fw-bold";
                    }
                })
                .catch(err => {
                    statusLabel.style.display = 'none';
                });
            } else {
                statusLabel.style.display = 'none';
            }
        }
    </script>
}
