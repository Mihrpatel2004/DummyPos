@model List<DummyPos.Models.OpenOrderViewModel>
@{
    ViewData["Title"] = "Running Tables";
    Layout = "_StaffsLayout";
}

<style>
    /* --- VIBRANT MULTI-COLOR BACKGROUND --- */
    .future-light-bg {
        background: linear-gradient(135deg, #f5f7fa 0%, #e4eefe 100%);
        background-attachment: fixed;
        min-height: 100vh;
        padding: 40px;
        margin: -20px;
        font-family: 'Poppins', sans-serif;
        position: relative;
        overflow: hidden;
    }

    /* Floating Colorful Orbs in Background */
    .future-light-bg::before {
        content: "";
        position: absolute;
        top: -10%; left: -10%;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(0, 210, 255, 0.2) 0%, transparent 70%);
        z-index: 0;
    }

    /* --- RAINBOW GLASS HEADER --- */
    .glass-header {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 24px;
        padding: 25px 40px;
        margin-bottom: 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 10px 40px rgba(58, 123, 213, 0.1);
        position: relative;
        z-index: 1;
    }

    .title-gradient {
        background: linear-gradient(90deg, #00C9FF 0%, #92FE9D 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 2rem;
        letter-spacing: -1px;
    }

    .btn-gradient {
        background: linear-gradient(45deg, #2193b0, #6dd5ed);
        color: white;
        border: none;
        border-radius: 15px;
        padding: 12px 25px;
        font-weight: 700;
        box-shadow: 0 4px 15px rgba(109, 213, 237, 0.4);
        transition: all 0.3s;
    }

    .btn-gradient:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(109, 213, 237, 0.6);
        color: white;
    }

    /* --- VIBRANT TABLE CARDS --- */
    .table-card-future {
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid transparent;
        border-radius: 30px;
        padding: 30px;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        position: relative;
    }

    /* Rainbow border on hover */
    .table-card-future:hover {
        transform: translateY(-15px);
        border-image: linear-gradient(45deg, #00C9FF, #92FE9D) 1;
        border: 2px solid #00C9FF;
        box-shadow: 0 20px 50px rgba(0, 201, 255, 0.2);
    }

    .table-id-pill {
        background: #f0f4f8;
        color: #546e7a;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        display: inline-block;
        margin-bottom: 15px;
    }

    .table-number-box {
        font-size: 3.5rem;
        font-weight: 900;
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
    }

    .price-badge {
        background: linear-gradient(90deg, #11998e, #38ef7d);
        color: white;
        padding: 10px 20px;
        border-radius: 15px;
        font-size: 1.4rem;
        font-weight: 800;
        display: inline-block;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(56, 239, 125, 0.3);
    }

    .detail-row {
        background: #f8fafc;
        border-radius: 15px;
        padding: 12px;
        display: flex;
        justify-content: space-around;
        margin-bottom: 25px;
    }

    .detail-item i { color: #3a7bd5; margin-right: 5px; }
    .detail-item span { font-weight: 600; color: #475569; font-size: 0.85rem; }

    /* --- ACTION BUTTON --- */
    .btn-open-order {
        background: #fff;
        color: #3a7bd5;
        border: 2px solid #3a7bd5;
        border-radius: 15px;
        padding: 12px;
        width: 100%;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
        text-decoration: none;
        display: block;
    }

    .btn-open-order:hover {
        background: #3a7bd5;
        color: #fff;
        box-shadow: 0 10px 20px rgba(58, 123, 213, 0.3);
    }

    /* --- EMPTY STATE --- */
    .empty-state {
        background: white;
        border-radius: 40px;
        padding: 100px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.05);
    }
</style>

<div class="future-light-bg">
    <div class="container-fluid">
        
        <div class="glass-header">
            <div>
                <h1 class="title-gradient">Floor Control</h1>
                <p class="m-0 text-muted fw-bold">
                    <span class="badge bg-info text-white rounded-pill px-3 mr-2">LIVE</span> 
                    Currently @Model.Count Active Tables
                </p>
            </div>
            <a href="@Url.Action("Order", "Staffs")" class="btn btn-gradient btn-lg">
                <i class="fas fa-plus-circle mr-2"></i> NEW ORDER
            </a>
        </div>

        <div class="row g-4 justify-content-center">
            @if (Model != null && Model.Count > 0)
            {
                foreach (var table in Model)
                {
                    <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                        <div class="table-card-future shadow-sm">
                            <span class="table-id-pill">ID: @table.Order_No</span>
                            
                            <div class="table-number-box">
                                @table.Table_Number
                            </div>
                            
                            <div class="price-badge">
                                ₹@table.GrandTotal.ToString("0.00")
                            </div>

                            <div class="detail-row">
                                <div class="detail-item">
                                    <i class="far fa-clock"></i>
                                    <span>@table.Order_Date.ToString("hh:mm tt")</span>
                                </div>
                                <div class="detail-item">
                                    <i class="fas fa-utensils"></i>
                                    <span>Dine-In</span>
                                </div>
                            </div>

                            <a href="@Url.Action("Order", "Staffs", new { orderId = table.Order_Id })" class="btn-open-order">
                                Manage Table
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-lg-8">
                    <div class="empty-state text-center">
                        <i class="fas fa-smile-beam fa-5x text-info mb-4"></i>
                        <h2 class="fw-bold text-dark">Ready for Business!</h2>
                        <p class="text-muted fs-5">All tables are currently free. Start a new order to see it here.</p>
                        <a href="@Url.Action("Order", "Staffs")" class="btn btn-gradient btn-lg mt-4 px-5">
                            Create First Order
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>