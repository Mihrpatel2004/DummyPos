@{
}
@model List<DummyPos.Models.KitchenOrderViewModel>
@{
    ViewData["Title"] = "Kitchen Display (KOT)";
    // You can set Layout = null; if you want the kitchen screen to be full-screen without menus!
    Layout = "_StaffsLayout"; 
}

<meta http-equiv="refresh" content="10">

<div class="container-fluid py-4 bg-dark min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4 text-white">
        <h2 class="fw-bold"><i class="fas fa-fire me-2 text-warning"></i> Kitchen Display System</h2>
        <span class="badge bg-danger fs-5">Live <i class="fas fa-circle ms-1" style="font-size: 10px; animation: blink 1s infinite;"></i></span>
    </div>

    <div class="row g-3">
        @if (Model != null && Model.Count > 0)
        {
            foreach (var order in Model)
            {
                <div class="col-12 col-md-4 col-lg-3">
                    <div class="card h-100 shadow rounded-0" style="background-color: #fffbc8; border-top: 5px solid #dc3545;">
                        <div class="card-header bg-transparent border-bottom-0 text-center pb-0">
                            <h2 class="fw-bold mb-0 text-danger">TABLE @order.Table_Number</h2>
                            <small class="text-muted fw-bold">@order.Order_No</small>
                            <div class="text-muted mt-1 mb-2"><i class="far fa-clock"></i> @order.Order_Date.ToString("hh:mm tt")</div>
                            <hr class="my-1 border-dark border-2 border-dashed">
                        </div>
                        
                        <div class="card-body py-2">
                            <ul class="list-unstyled mb-0 fs-5 fw-bold text-dark">
                                @foreach (var item in order.Items)
                                {
                                    <li class="d-flex justify-content-between border-bottom border-secondary py-2">
                                        <span>@item.Item_Name</span>
                                        <span class="badge bg-dark rounded-pill fs-6 d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                            @item.Quantity
                                        </span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 mt-5 text-white">
                <i class="fas fa-check-double fa-4x text-success mb-3"></i>
                <h3 class="fw-bold text-light">All caught up!</h3>
                <p class="text-secondary fs-5">No active orders right now. Kitchen is clear.</p>
            </div>
        }
    </div>
</div>

<style>
    /* Gives the tickets a paper-like dashed line */
    .border-dashed { border-style: dashed !important; }
    
    /* Makes the red "Live" dot pulse */
    @@keyframes blink {
        0% { opacity: 1; }
        50% { opacity: 0; }
        100% { opacity: 1; }
    }
</style>