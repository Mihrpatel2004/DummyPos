@model DummyPos.Models.Staffs
@{
    ViewData["Title"] = "Staff Profile";
    Layout = "~/Views/Shared/_StaffsLayout.cshtml"; 

    // Safely get the first letter
    string firstLetter = "S";
    if (!string.IsNullOrEmpty(Model?.Staff_Name))
    {
        firstLetter = Model.Staff_Name.Substring(0, 1).ToUpper();
    }
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
    /* --- VIBRANT FUTURE-LIGHT BACKGROUND --- */
    .profile-wrapper {
        background: radial-gradient(circle at top right, #fff7ed, #f8fafc 50%),
                    radial-gradient(circle at bottom left, #fff1e0, #ffffff 100%);
        background-attachment: fixed;
        min-height: 100vh;
        padding: 50px 20px;
        margin: -20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* --- HOLOGRAPHIC AVATAR SECTION --- */
    .profile-hero {
        text-align: center;
        margin-bottom: 40px;
    }

    .avatar-hologram {
        width: 140px;
        height: 140px;
        background: linear-gradient(135deg, #e67e22, #f39c12);
        color: white;
        font-size: 65px;
        font-weight: 800;
        border-radius: 40px; /* Modern "Squircle" shape */
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
        box-shadow: 0 20px 40px rgba(230, 126, 34, 0.3);
        border: 5px solid white;
        position: relative;
    }

    .avatar-hologram::after {
        content: "";
        position: absolute;
        width: 110%;
        height: 110%;
        border: 2px dashed #e67e22;
        border-radius: 45px;
        animation: rotate-slow 12s linear infinite;
        opacity: 0.3;
    }

    @@keyframes rotate-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .profile-title {
        font-weight: 900;
        font-size: 2.2rem;
        color: #1e293b;
        letter-spacing: -1.5px;
        margin-bottom: 5px;
    }

    .role-badge {
        background: #fff7ed;
        color: #e67e22;
        padding: 6px 20px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.8rem;
        text-transform: uppercase;
        display: inline-block;
        border: 1px solid rgba(230, 126, 34, 0.1);
    }

    /* --- INFO CARDS (GLASSMORPHISM) --- */
    .glass-profile-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 32px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.04);
    }

    .section-label {
        font-size: 0.8rem;
        font-weight: 800;
        color: #e67e22;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 30px;
        display: block;
        border-left: 4px solid #e67e22;
        padding-left: 12px;
    }

    /* Info Node Styling */
    .info-node {
        margin-bottom: 25px;
        padding: 20px;
        background: #f8fafc;
        border-radius: 20px;
        border: 1px solid #f1f5f9;
        transition: all 0.3s;
    }

    .info-node:hover {
        background: white;
        transform: scale(1.02);
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        border-color: #e67e22;
    }

    .node-label {
        font-size: 0.7rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }

    .node-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        display: block;
    }

    .icon-box {
        width: 40px;
        height: 40px;
        background: white;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #e67e22;
        margin-bottom: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .btn-dashboard {
        background: white;
        color: #1e293b;
        border: 2px solid #f1f5f9;
        padding: 15px 30px;
        border-radius: 18px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: 100%;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-dashboard:hover {
        background: #f8fafc;
        border-color: #e67e22;
        color: #e67e22;
    }
</style>

<div class="profile-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-9 col-lg-10">

                @if (Model != null)
                {
                    <div class="profile-hero">
                        <div class="avatar-hologram">
                            @firstLetter
                        </div>
                        <h1 class="profile-title">@Model.Staff_Name</h1>
                        <span class="role-badge">
                            <i class="fas fa-user-tag mr-1"></i> @(!string.IsNullOrEmpty(Model.Role_Name) ? Model.Role_Name : "Team Professional")
                        </span>
                    </div>

                    <div class="glass-profile-card">
                        <span class="section-label">Employee Profile</span>

                        <div class="row">
                            <div class="col-md-12">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-signature"></i></div>
                                    <span class="node-label">Official Name</span>
                                    <span class="node-value">@Model.Staff_Name</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-envelope-open"></i></div>
                                    <span class="node-label">Work Email</span>
                                    <span class="node-value">@(string.IsNullOrEmpty(Model.Email) ? "Not Provided" : Model.Email)</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-mobile-alt"></i></div>
                                    <span class="node-label">Mobile Number</span>
                                    <span class="node-value">@(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node" style="border-left: 4px solid #e67e22;">
                                    <div class="icon-box"><i class="fas fa-map-marked-alt"></i></div>
                                    <span class="node-label">Active Branch</span>
                                    <span class="node-value">
                                        @(string.IsNullOrEmpty(Model.Branch_Name) ? "Global Floating Support" : Model.Branch_Name)
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-node">
                                    <div class="icon-box"><i class="fas fa-calendar-check"></i></div>
                                    <span class="node-label">Member Since</span>
                                    <span class="node-value">
                                        @(Model.Hire_Date != null && Model.Hire_Date.Value.Year > 2000 ? Model.Hire_Date.Value.ToString("dd MMMM, yyyy") : "Foundation Member")
                                    </span>
                                </div>
                            </div>

                            <div class="col-md-12 mt-3">
                                <a href="@Url.Action("Order", "Staffs")" class="btn-dashboard">
                                    <i class="fas fa-th-large mr-2"></i> Return to Order
                                </a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="glass-profile-card text-center py-5">
                        <i class="fas fa-user-slash fa-4x text-warning mb-4"></i>
                        <h2 class="fw-bold">Profile Unavailable</h2>
                        <p class="text-muted">The system is unable to sync with your personnel record. Please re-login.</p>
                        <a href="/" class="btn btn-warning rounded-pill px-5 py-2 mt-3 text-white">Retry Connection</a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>