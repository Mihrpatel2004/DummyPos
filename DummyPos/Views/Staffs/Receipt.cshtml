@model DummyPos.Models.ReceiptViewModel
@{
    ViewData["Title"] = "Order Receipt";
    Layout = "_StaffsLayout";
}

<style>
    .receipt-wrapper {
        display: flex;
        justify-content: center;
        padding: 40px;
        background-color: #f0f0f0;
        min-height: calc(100vh - 60px);
    }
    .receipt-paper {
        background: white;
        width: 350px; 
        padding: 20px;
        font-family: 'Courier New', Courier, monospace; 
        color: #000;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
    .dashed-line {
        border-top: 1px dashed #000;
        margin: 10px 0;
    }
    
    @@media print {
        body * { visibility: hidden; }
        .receipt-paper, .receipt-paper * { visibility: visible; }
        .receipt-paper {
            position: absolute;
            left: 0; top: 0;
            width: 100%;
            box-shadow: none;
            padding: 0;
        }
        .no-print { display: none !important; }
    }
</style>

<div class="receipt-wrapper">
    <div class="receipt-paper">
        
        <div class="text-center mb-3">
            <h2 class="fw-bold mb-0">PIZZA Restaurant </h2>
            <h3 class="fw-bold mb-0">@Model.Branch_Name</h3>
            <div style="font-size: 0.85rem; line-height: 1.4;">
                Shop No. 42, Supermarket Complex<br />
                Main Road, @Model.Branch_Name, Gujarat 395003<br />
            
        </div>
        
        <div class="dashed-line"></div>

        <div class="mb-2" style="font-size: 0.9rem;">
            <div><strong>Order No:</strong> @Model.Order_No</div>
            <div><strong>Date:</strong> @Model.Order_Date.ToString("dd/MM/yyyy hh:mm tt")</div>
            <div><strong>Staff:</strong> @Model.Staff_Name</div>
            <div><strong>Customer:</strong> @Model.Customer_Name</div>
            @if(!string.IsNullOrEmpty(Model.Customer_Phone))
            {
                <div><strong>Phone:</strong> @Model.Customer_Phone</div>
            }
        </div>

        <div class="dashed-line"></div>

        <table class="w-100 mb-2" style="font-size: 0.9rem;">
            <thead>
                <tr>
                    <th class="text-start pb-1">Item</th>
                    <th class="text-center pb-1">Qty</th>
                    <th class="text-end pb-1">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model.Items)
                {
                    <tr>
                        <td class="text-start pe-2">@item.Item_Name</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.Total_Price.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="dashed-line"></div>

        <div class="d-flex justify-content-between" style="font-size: 0.9rem;">
            <span>Subtotal:</span>
            <span>₹@Model.SubTotal.ToString("0.00")</span>
        </div>

        @if (Model.DiscountAmount > 0)
        {
            <div class="d-flex justify-content-between text-success fw-bold" style="font-size: 0.9rem;">
                <span>Discount Applied:</span>
                <span>- ₹@Model.DiscountAmount.ToString("0.00")</span>
            </div>
        }

        <div class="d-flex justify-content-between" style="font-size: 0.9rem;">
            <span>GST (18%):</span>
            <span>₹@Model.TaxAmount.ToString("0.00")</span>
        </div>
        
        <div class="dashed-line"></div>
        
        <div class="d-flex justify-content-between fw-bold fs-5 my-2">
            <span>TOTAL:</span>
            <span>₹@Model.GrandTotal.ToString("0.00")</span>
        </div>
        
        <div class="dashed-line"></div>

        <div class="text-center mt-3" style="font-size: 0.85rem;">
            <p class="mb-1"><strong>Paid By:</strong> @Model.Payment_Type</p>
            <p class="mb-3">Transaction ID: TXN-@Model.Order_Id@DateTime.Now.Millisecond</p>
            
            <h6 class="fw-bold mt-4">THANK YOU FOR YOUR VISIT!</h6>
            <p>Please visit us again.</p>
        </div>

        <div class="text-center mt-4 no-print">
            <button class="btn btn-dark w-100 mb-2 fw-bold" onclick="window.print()">
                <i class="fas fa-print me-2"></i> Print Receipt
            </button>
            <a href="@Url.Action("RunningTables", "Staffs")" class="btn btn-outline-danger w-100 fw-bold">
                <i class="fas fa-arrow-left me-2"></i> Back to Tables
            </a>
        </div>

    </div>
</div>